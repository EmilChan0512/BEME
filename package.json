{
  "name": "beme-fullstack-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "npm run dev -w @beme/web",
    "dev:api": "npm run dev -w @beme/api",
    "build": "npm run build -w @beme/shared && npm run build -w @beme/api && npm run build -w @beme/web",
    "type-check": "npm run type-check -ws",
    "lint": "npm run lint -ws"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
